<%- include('partials/head', { title: 'Configurar 2º fator', bodyClass: 'auth', assetVersion: locals.assetVersion }) %>
  <main class="auth-screen">
    <div class="auth-bg" aria-hidden="true"></div>
    <div class="auth-card auth-card-wide">
      <div class="auth-bracket auth-bracket-tl"></div>
      <div class="auth-bracket auth-bracket-tr"></div>
      <div class="auth-bracket auth-bracket-bl"></div>
      <div class="auth-bracket auth-bracket-br"></div>

      <div class="auth-brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32">
            <path d="M2 12 L7 12 L9 6 L12 18 L15 9 L17 12 L22 12"
                  stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                  stroke-linejoin="round" fill="none" />
          </svg>
        </span>
        <h1 class="auth-brand-name">PULSO</h1>
        <span class="auth-brand-sub">2º FATOR</span>
      </div>

      <p class="auth-eyebrow">setup inicial</p>
      <h2 class="auth-title">Configurar autenticação</h2>
      <p class="auth-greeting">Olá, <strong><%= user.name || user.email %></strong>. Antes de seguir, configure o segundo fator.</p>

      <ol class="steps">
        <li>Abra o Google Authenticator (ou Authy, 1Password).</li>
        <li>Escaneie o QR code abaixo, ou digite o código manualmente.</li>
        <li>Insira o código de 6 dígitos pra confirmar.</li>
      </ol>

      <div class="totp-grid">
        <div class="totp-qr">
          <img src="<%= qrDataUrl %>" alt="QR code do segundo fator" />
        </div>
        <div class="totp-manual">
          <label class="form-label">Código manual</label>
          <code class="totp-secret"><%= secretBase32 %></code>
        </div>
      </div>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/totp/setup" class="totp-form">
        <label class="form-label" for="token">Código do app</label>
        <input
          type="text" id="token" name="token"
          inputmode="numeric" pattern="[0-9 ]{6,7}" maxlength="7"
          autocomplete="one-time-code" autofocus required
        />
        <button type="submit" class="btn btn-primary btn-block">Ativar 2º fator</button>
      </form>

      <form method="POST" action="/logout" class="logout-form-inline">
        <button type="submit" class="btn btn-ghost btn-small">Sair</button>
      </form>
    </div>
  </main>
<%- include('partials/footer') %>

<%- include('partials/head', { title: 'Configurar 2º fator', bodyClass: 'auth' }) %>
  <main class="auth-card auth-card-wide">
    <div class="brand brand-large">
      <span class="brand-dot"></span>
      <span class="brand-name">Configurar 2º fator</span>
    </div>
    <p class="muted">Olá, <strong><%= user.name || user.email %></strong>. Antes de seguir, configure o segundo fator de autenticação.</p>

    <ol class="steps">
      <li>Abra o Google Authenticator (ou Authy, 1Password, etc).</li>
      <li>Escaneie o QR code abaixo, ou digite o código manualmente.</li>
      <li>Insira o código de 6 dígitos gerado pelo app pra confirmar.</li>
    </ol>

    <div class="totp-grid">
      <div class="totp-qr">
        <img src="<%= qrDataUrl %>" alt="QR code do segundo fator" />
      </div>
      <div class="totp-manual">
        <label class="form-label">Código manual</label>
        <code class="totp-secret"><%= secretBase32 %></code>
      </div>
    </div>

    <% if (error) { %>
      <div class="alert alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/totp/setup" class="totp-form">
      <label class="form-label" for="token">Código do app</label>
      <input
        type="text"
        id="token"
        name="token"
        inputmode="numeric"
        pattern="[0-9 ]{6,7}"
        maxlength="7"
        autocomplete="one-time-code"
        autofocus
        required
      />
      <button type="submit" class="btn btn-primary btn-block">Ativar 2º fator</button>
    </form>

    <form method="POST" action="/logout" class="logout-form-inline">
      <button type="submit" class="btn btn-ghost btn-small">Sair</button>
    </form>
  </main>
<%- include('partials/footer') %>

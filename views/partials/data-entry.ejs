<datalist id="categorias-list">
  <% for (const [grp, items] of Object.entries(categoriesByGroup)) { %>
    <% for (const item of items) { %>
      <% if (item !== 'Tráfego Pago (Google / Meta Ads)') { %>
        <option value="<%= item %>"><%= grp %></option>
      <% } %>
    <% } %>
  <% } %>
</datalist>

<dialog id="modal-venda" class="modal">
  <form class="api-form" data-endpoint="/api/sales" data-method="POST" id="form-venda">
    <h2>Nova venda</h2>

    <div class="venda-mode-toggle">
      <label class="radio-label"><input type="radio" name="venda_mode" value="paid" checked /> 100% paga hoje</label>
      <label class="radio-label"><input type="radio" name="venda_mode" value="installments" /> Parcelada</label>
    </div>

    <label class="form-label">Data
      <input type="date" name="date" value="<%= today %>" required />
    </label>
    <div class="form-row">
      <label class="form-label">Valor bruto (R$)
        <input type="number" name="gross_amount" step="0.01" min="0" required />
      </label>
      <label class="form-label">Valor líquido (R$) <span class="muted">(parte paga hoje)</span>
        <input type="number" name="net_amount" step="0.01" min="0" required />
      </label>
    </div>
    <label class="form-label">Cliente
      <input type="text" name="client_name" placeholder="Opcional" />
    </label>
    <div class="form-row">
      <label class="form-label">Closer
        <select name="closer_id">
          <option value="">—</option>
          <% for (const c of closers) { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% } %>
        </select>
      </label>
      <label class="form-label">Pagamento
        <select name="payment_method">
          <option value="">—</option>
          <option value="pix">Pix</option>
          <option value="cartao_avista">Cartão à vista</option>
          <option value="cartao_2x">Cartão 2x</option>
          <option value="cartao_6x">Cartão 6x</option>
          <option value="cartao_12x">Cartão 12x</option>
          <option value="outro">Outro</option>
        </select>
      </label>
    </div>
    <label class="form-label">Observações
      <textarea name="notes" rows="2"></textarea>
    </label>

    <div id="installments-block" hidden>
      <h3>Parcelas futuras</h3>
      <table class="installments-table">
        <thead>
          <tr><th>Data prevista</th><th class="num">Valor</th><th>Pagamento</th><th></th></tr>
        </thead>
        <tbody id="installments-tbody"></tbody>
      </table>
      <button type="button" class="btn btn-ghost btn-small" id="btn-add-installment">+ Adicionar parcela</button>
      <p class="muted installments-summary" id="installments-summary"></p>
    </div>

    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar venda</button>
    </div>
  </form>
</dialog>

<dialog id="modal-custo" class="modal">
  <form class="api-form" data-endpoint="/api/costs" data-method="POST">
    <h2>Novo custo</h2>
    <div class="form-row">
      <label class="form-label">Data
        <input type="date" name="date" value="<%= today %>" required />
      </label>
      <label class="form-label">Valor (R$)
        <input type="number" name="amount" step="0.01" min="0" required />
      </label>
    </div>
    <label class="form-label">Categoria
      <input list="categorias-list" name="category" required placeholder="Selecione ou digite uma nova" />
    </label>
    <label class="form-label">Descrição
      <input type="text" name="description" />
    </label>
    <div class="form-row">
      <label class="form-label">Status
        <select name="status">
          <option value="planned">Previsto</option>
          <option value="paid">Pago</option>
        </select>
      </label>
      <label class="form-label">Cenário
        <select name="scenario_id">
          <option value="">Realidade (todos cenários)</option>
          <% if (activeScenario) { %>
            <option value="<%= activeScenario.id %>">Apenas neste (<%= activeScenario.name %>)</option>
          <% } %>
        </select>
      </label>
    </div>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar custo</button>
    </div>
  </form>
</dialog>

<dialog id="modal-custo-parcelado" class="modal">
  <form id="form-custo-parcelado">
    <h2>Custo parcelado</h2>
    <p class="muted">Cria N custos independentes a partir de um total. Edição manual de cada data é permitida.</p>
    <label class="form-label">Categoria
      <input list="categorias-list" name="category" required placeholder="Selecione ou digite uma nova" />
    </label>
    <label class="form-label">Descrição
      <input type="text" name="description" placeholder='ex: Lays - mar/abr/mai/jun' />
    </label>
    <div class="form-row">
      <label class="form-label">Valor TOTAL (R$)
        <input type="number" name="total_amount" step="0.01" min="0" required />
      </label>
      <label class="form-label">Nº de parcelas
        <input type="number" name="installments_count" min="2" max="36" value="2" required />
      </label>
    </div>
    <div class="form-row">
      <label class="form-label">Data da 1ª parcela
        <input type="date" name="first_date" value="<%= today %>" required />
      </label>
      <label class="form-label">Frequência
        <select name="frequency">
          <option value="monthly" selected>Mensal (mesmo dia do mês)</option>
          <option value="biweekly">Quinzenal (a cada 14 dias)</option>
          <option value="weekly">Semanal (a cada 7 dias)</option>
          <option value="custom">Custom (datas manuais)</option>
        </select>
      </label>
    </div>
    <div class="parcel-preview" id="parcel-preview">
      <div class="parcel-preview-head">
        <span>Pré-visualização das parcelas</span>
        <span class="parcel-sum-check" id="parcel-sum-check"></span>
      </div>
      <ul class="parcel-list" id="parcel-list"></ul>
    </div>
    <label class="form-label">Cenário (opcional)
      <select name="scenario_id">
        <option value="">Realidade (todos cenários)</option>
        <% if (activeScenario) { %>
          <option value="<%= activeScenario.id %>">Apenas neste (<%= activeScenario.name %>)</option>
        <% } %>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary" id="btn-submit-parcelado">Criar parcelas</button>
    </div>
  </form>
</dialog>

<dialog id="modal-recorrente" class="modal">
  <form class="api-form" data-endpoint="/api/costs" data-method="POST">
    <input type="hidden" name="is_recurring" value="true" />
    <h2>Custo recorrente</h2>
    <label class="form-label">Categoria
      <input list="categorias-list" name="category" required />
    </label>
    <label class="form-label">Descrição
      <input type="text" name="description" />
    </label>
    <label class="form-label">Valor base (R$)
      <input type="number" name="amount" step="0.01" min="0" required />
    </label>
    <div class="form-row">
      <label class="form-label">Padrão
        <select name="recurrence_pattern">
          <option value="monthly_day">Mensal (dia X)</option>
          <option value="every_n_weeks">A cada N semanas</option>
        </select>
      </label>
      <label class="form-label">
        <span id="recurrence-value-label">Dia do mês (1-31)</span>
        <input type="number" name="recurrence_value" min="1" max="31" value="5" required />
      </label>
    </div>
    <div class="form-row">
      <label class="form-label">Início
        <input type="date" name="recurrence_start" value="<%= today %>" required />
      </label>
      <label class="form-label">Fim (opcional)
        <input type="date" name="recurrence_end" />
      </label>
    </div>
    <label class="form-label">Cenário
      <select name="scenario_id">
        <option value="">Realidade (todos cenários)</option>
        <% if (activeScenario) { %>
          <option value="<%= activeScenario.id %>">Apenas neste (<%= activeScenario.name %>)</option>
        <% } %>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Criar recorrência</button>
    </div>
  </form>
</dialog>

<dialog id="modal-edit-ads-week" class="modal">
  <form id="form-edit-ads-week">
    <h2>Editar Ads da semana</h2>
    <p class="muted" id="edit-ads-context"></p>
    <input type="hidden" name="week_start_date" />
    <label class="form-label">Valor total da semana (R$)
      <input type="number" name="total_amount" step="0.01" min="0" required />
    </label>
    <p class="ads-preview muted" id="edit-ads-preview"></p>
    <label class="form-label">Cenário
      <select name="scenario_id">
        <option value="">Realidade (todos cenários)</option>
        <% if (activeScenario) { %>
          <option value="<%= activeScenario.id %>">Apenas neste (<%= activeScenario.name %>)</option>
        <% } %>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
  </form>
</dialog>

<dialog id="modal-ads" class="modal">
  <form id="form-ads">
    <h2>Investimento em Ads (semanal)</h2>
    <p class="muted">O valor será dividido em 7 dias da semana (dom→sáb). Lançar de novo na mesma semana sobrescreve.</p>
    <label class="form-label">Semana (qualquer data dentro dela)
      <input type="date" name="week_start_date" value="<%= today %>" required />
    </label>
    <label class="form-label">Valor da semana (R$)
      <input type="number" name="total_amount" step="0.01" min="0" required />
    </label>
    <p class="ads-preview muted" id="ads-preview"></p>
    <label class="form-label">Cenário
      <select name="scenario_id">
        <option value="">Realidade (todos cenários)</option>
        <% if (activeScenario) { %>
          <option value="<%= activeScenario.id %>">Apenas neste (<%= activeScenario.name %>)</option>
        <% } %>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar investimento</button>
    </div>
  </form>
</dialog>

<dialog id="modal-todos-futuros" class="modal modal-wide">
  <div class="modal-head">
    <h2>Todos os custos futuros</h2>
    <button type="button" class="btn btn-ghost btn-small" data-close-modal>Fechar</button>
  </div>
  <p class="muted">Lista todos os custos com data a partir de hoje. Filtre por status, categoria ou cenário. Edite ou exclua direto na lista.</p>
  <div class="future-toolbar">
    <label class="form-label">Status
      <select id="future-filter-status">
        <option value="planned" selected>A pagar (previstos)</option>
        <option value="paid">Pagos (futuros)</option>
        <option value="all">Todos</option>
      </select>
    </label>
    <label class="form-label">Categoria
      <select id="future-filter-category"><option value="">Todas</option></select>
    </label>
    <label class="form-label">Cenário
      <select id="future-filter-scenario">
        <option value="">Todos</option>
        <option value="null">Realidade (sem cenário)</option>
        <% if (typeof scenarios !== 'undefined' && scenarios) { %>
          <% for (const s of scenarios) { %>
            <option value="<%= s.id %>"><%= s.name %></option>
          <% } %>
        <% } %>
      </select>
    </label>
    <label class="form-label">Buscar
      <input type="search" id="future-filter-search" placeholder="Categoria, descrição…" />
    </label>
    <div class="future-summary" id="future-summary"></div>
  </div>
  <div class="future-table-wrap">
    <table class="future-table">
      <thead>
        <tr>
          <th>Data</th>
          <th>Categoria</th>
          <th>Descrição</th>
          <th class="num">Valor</th>
          <th>Status</th>
          <th>Cenário</th>
          <th>Ações</th>
        </tr>
      </thead>
      <tbody id="future-tbody">
        <tr><td colspan="7" class="muted center">Carregando…</td></tr>
      </tbody>
    </table>
  </div>
</dialog>

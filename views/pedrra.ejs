<%- include('partials/head', { title: title, assetVersion: locals.assetVersion }) %>
<%- include('partials/header', { title: title, user: user, userCan: userCan, scenarios: locals.scenarios, activeScenario: locals.activeScenario, assetVersion: locals.assetVersion }) %>

<main class="container pedrra">

  <section class="toolbar">
    <div class="toolbar-actions">
      <button type="button" class="btn btn-primary" data-modal="venda">+ Venda</button>
      <button type="button" class="btn btn-primary" data-modal="custo">+ Custo</button>
      <button type="button" class="btn btn-ghost" data-modal="recorrente">+ Custo recorrente</button>
      <button type="button" class="btn btn-warn" data-modal="ads">+ Investimento em Ads</button>
    </div>
  </section>

  <%- include('partials/data-entry', { closers: closers, activeScenario: activeScenario, today: today, categoriesByGroup: categoriesByGroup }) %>

  <% if (upcomingReceivables.length > 0) { %>
    <div class="alert alert-warn upcoming-receivables">
      <strong>⚠ <%= upcomingReceivables.length %> recebível(is) vencendo nos próximos 7 dias</strong>
      · total <%= formatBrl(upcomingReceivablesTotal) %>
      · <a href="/custos#receivables">ver detalhes</a>
    </div>
  <% } %>

  <section class="kpi-bar kpi-bar-6">
    <div class="kpi-card kpi-primary">
      <span class="kpi-card-label">Caixa hoje</span>
      <span class="kpi-card-value strong" data-final-value="<%= cashToday %>" data-format="brl" data-compact="1"><%= formatBrl(cashToday) %></span>
    </div>
    <div class="kpi-card">
      <span class="kpi-card-label">Runway (cenário ativo)</span>
      <span class="kpi-card-value strong">
        <%= typeof runway.runway_weeks === 'number' ? runway.runway_weeks.toFixed(1) + ' sem' : runway.runway_weeks %>
      </span>
      <% if (runway.weekly_burn > 0) { %>
        <span class="kpi-card-foot muted">queima ~<%= formatBrl(runway.weekly_burn) %>/sem</span>
      <% } %>
    </div>
    <div class="kpi-card">
      <span class="kpi-card-label">Sem. passada</span>
      <span class="kpi-card-value <%= lastWeekResult >= 0 ? 'pos' : 'neg' %>" data-final-value="<%= lastWeekResult %>" data-format="brl"><%= formatBrl(lastWeekResult) %></span>
    </div>
    <div class="kpi-card">
      <span class="kpi-card-label">Sem. atual</span>
      <span class="kpi-card-value <%= currentWeekResult >= 0 ? 'pos' : 'neg' %>" data-final-value="<%= currentWeekResult %>" data-format="brl"><%= formatBrl(currentWeekResult) %></span>
    </div>
    <div class="kpi-card">
      <span class="kpi-card-label">Próx. 2 sem (proj.)</span>
      <span class="kpi-card-value <%= projection2Weeks >= 0 ? 'pos' : 'neg' %>" data-final-value="<%= projection2Weeks %>" data-format="brl"><%= formatBrl(projection2Weeks) %></span>
    </div>
    <div class="kpi-card">
      <span class="kpi-card-label">Ads sem. atual</span>
      <span class="kpi-card-value ads-color" data-final-value="<%= adsCurrentWeek %>" data-format="brl"><%= formatBrl(adsCurrentWeek) %></span>
    </div>
  </section>

  <section class="chart-controls">
    <label>Janela passada
      <select id="past-weeks">
        <option value="1" selected>1 sem</option>
        <option value="2">2 sem</option>
        <option value="4">4 sem</option>
        <option value="8">8 sem</option>
      </select>
    </label>
    <label>Futuro
      <select id="future-weeks">
        <option value="2" selected>2 sem</option>
        <option value="4">4 sem</option>
        <option value="8">8 sem</option>
        <option value="12">12 sem</option>
      </select>
    </label>
    <span class="chart-status muted" id="chart-status"></span>
  </section>

  <section class="chart-wrap">
    <canvas id="cashflow-chart" height="320"></canvas>
  </section>

  <section class="projection-table-wrap">
    <h3>Projeção semana a semana <span class="muted">(edite "vendas projetadas" pra simular)</span></h3>
    <table class="projection-table" id="projection-table">
      <thead>
        <tr>
          <th>Semana</th>
          <th class="num">Vendas (real/proj)</th>
          <th class="num">Custos</th>
          <th class="num">Ads</th>
          <th class="num">Saldo da sem.</th>
          <th class="num">Caixa após</th>
        </tr>
      </thead>
      <tbody></tbody>
    </table>
  </section>
</main>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<script>
  window.PEDRRA_INITIAL = <%- JSON.stringify({
    series: cashflow.series,
    cashAtStart: cashflow.cash_at_start,
    cashToday: cashflow.cash_today,
    projectedWeeklyNet: cashflow.projected_weekly_net || 0,
    activeScenario: activeScenario,
    visibleScenarioIds: visibleScenarioIds,
    includeReceivablesInProjection: !!cashflow.include_receivables_in_projection,
    includeAdsInRunway: cashflow.include_ads_in_runway !== false,
  }) %>;
</script>
<script src="/js/data-entry.js?v=<%= assetVersion %>"></script>
<script src="/js/pedrra.js?v=<%= assetVersion %>"></script>
<%- include('partials/footer') %>

<%- include('partials/head', { title: title, assetVersion: locals.assetVersion }) %>
<%- include('partials/header', { title: title, user: user, userCan: userCan, scenarios: locals.scenarios, activeScenario: locals.activeScenario, assetVersion: locals.assetVersion }) %>

<main class="container settings-page">

  <section class="settings-card">
    <h2>Saldo e cálculos</h2>
    <form id="form-settings" class="settings-form">
      <label class="form-label">Saldo inicial em conta (R$)
        <input type="number" name="initial_cash_brl" min="0" step="0.01" value="<%= settings.initial_cash_brl || 0 %>" />
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="include_initial_cash" value="1" <%= settings.include_initial_cash === '1' ? 'checked' : '' %> />
        Incluir saldo inicial no cálculo de caixa e runway
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="include_ads_in_runway" value="1" <%= settings.include_ads_in_runway === '1' ? 'checked' : '' %> />
        Considerar Ads no cálculo do Saldo e Runway
      </label>
      <label class="checkbox-label">
        <input type="checkbox" name="include_receivables_in_projection" value="1" <%= settings.include_receivables_in_projection === '1' ? 'checked' : '' %> />
        Incluir recebíveis na projeção de caixa do PEDRRA
      </label>
      <label class="form-label">Taxa de pagamento padrão (%)
        <input type="number" name="default_payment_tax_pct" min="0" max="100" step="0.1" value="<%= settings.default_payment_tax_pct || 12 %>" />
      </label>
      <button type="submit" class="btn btn-primary">Salvar configurações</button>
      <span class="settings-status" id="settings-status"></span>
    </form>
  </section>

  <section class="settings-card">
    <h2>Time comercial</h2>
    <p class="muted">SDRs e Closers que aparecem no funil e como closer responsável nas vendas.</p>
    <form id="form-team-add" class="settings-form-inline">
      <input type="text" name="name" placeholder="Nome" required />
      <select name="role" required>
        <option value="sdr">SDR</option>
        <option value="closer">Closer</option>
      </select>
      <button type="submit" class="btn btn-primary btn-small">+ Adicionar</button>
    </form>
    <table class="team-table">
      <thead>
        <tr><th>Nome</th><th>Função</th><th>Status</th><th></th></tr>
      </thead>
      <tbody id="team-tbody">
        <% for (const m of team) { %>
          <tr data-id="<%= m.id %>">
            <td><%= m.name %></td>
            <td><%= m.role === 'sdr' ? 'SDR' : 'Closer' %></td>
            <td><%= m.active ? 'Ativo' : 'Inativo' %></td>
            <td>
              <button type="button" class="btn-link" data-action="toggle" data-id="<%= m.id %>" data-active="<%= m.active %>"><%= m.active ? 'desativar' : 'reativar' %></button>
              <button type="button" class="btn-link danger" data-action="remove" data-id="<%= m.id %>" data-name="<%- m.name.replace(/"/g, '&quot;') %>">remover</button>
            </td>
          </tr>
        <% } %>
        <% if (team.length === 0) { %>
          <tr><td colspan="4" class="muted center">Nenhum membro cadastrado.</td></tr>
        <% } %>
      </tbody>
    </table>
  </section>

  <section class="settings-card">
    <h2>Categorias de custo</h2>
    <p class="muted">Organize as categorias por grupo. Renomear uma categoria atualiza automaticamente todos os custos que a usam.</p>
    <button type="button" class="btn btn-primary btn-small" id="btn-new-category">+ Nova categoria</button>
    <div class="cat-groups" id="cat-groups">
      <% for (const grp of orderedGroups) { %>
        <div class="cat-group">
          <h3><%= grp %></h3>
          <ul class="cat-list">
            <% for (const c of (categoriesGrouped[grp] || [])) { %>
              <li data-id="<%= c.id %>">
                <span class="cat-name"><%= c.name %></span>
                <span class="cat-actions">
                  <button type="button" class="btn-link" data-action="edit-category" data-id="<%= c.id %>" data-name="<%- c.name.replace(/"/g, '&quot;') %>" data-group="<%- c.group_name.replace(/"/g, '&quot;') %>">editar</button>
                  <button type="button" class="btn-link danger" data-action="delete-category" data-id="<%= c.id %>" data-name="<%- c.name.replace(/"/g, '&quot;') %>">excluir</button>
                </span>
              </li>
            <% } %>
          </ul>
        </div>
      <% } %>
    </div>
  </section>

  <section class="settings-card">
    <h2>Permissões — Rachel <span class="muted">(role: financeiro)</span></h2>
    <p class="muted">Marque o que a Rachel pode acessar e fazer. Master sempre tem acesso total. Mudanças aplicam após próximo login dela.</p>
    <form id="form-permissions" class="settings-form">
      <% for (const grp of permGroupOrder) { %>
        <% if (permsByGroup[grp] && permsByGroup[grp].length > 0) { %>
          <div class="perm-group">
            <h3><%= grp %></h3>
            <% for (const p of permsByGroup[grp]) { %>
              <label class="checkbox-label">
                <input type="checkbox" data-perm-key="<%= p.key %>" <%= p.allowed ? 'checked' : '' %> />
                <%= p.label %>
                <span class="muted code-tag"><%= p.key %></span>
              </label>
            <% } %>
          </div>
        <% } %>
      <% } %>
      <button type="submit" class="btn btn-primary">Salvar permissões</button>
      <span class="settings-status" id="perm-status"></span>
    </form>
  </section>

  <section class="settings-card">
    <h2>Backup e exportação</h2>
    <p class="muted">Exporta o estado atual do banco em JSON (todas as tabelas exceto users/sessões).</p>
    <a class="btn btn-primary" href="/api/export" download>Exportar JSON completo</a>
  </section>

  <section class="settings-card">
    <h2>Audit log <span class="muted">(últimas <%= auditEntries.length %> entradas)</span></h2>
    <div class="audit-table-wrap">
      <table class="audit-table">
        <thead>
          <tr><th>Quando</th><th>Quem</th><th>Ação</th><th>Entidade</th><th>ID</th></tr>
        </thead>
        <tbody>
          <% for (const a of auditEntries) { %>
            <tr>
              <td class="muted"><%= a.created_at %></td>
              <td><%= a.user_email %></td>
              <td><span class="badge action-<%= a.action.toLowerCase() %>"><%= a.action %></span></td>
              <td><%= a.entity_type %></td>
              <td><%= a.entity_id || '—' %></td>
            </tr>
          <% } %>
          <% if (auditEntries.length === 0) { %>
            <tr><td colspan="5" class="muted center">Nenhuma entrada ainda.</td></tr>
          <% } %>
        </tbody>
      </table>
    </div>
  </section>

</main>

<dialog id="modal-category" class="modal">
  <form id="form-category">
    <h2 id="modal-cat-title">Nova categoria</h2>
    <input type="hidden" name="id" />
    <label class="form-label">Nome
      <input type="text" name="name" required />
    </label>
    <label class="form-label">Grupo
      <select name="group_name" required>
        <% for (const g of groupOrder) { %>
          <option value="<%= g %>"><%= g %></option>
        <% } %>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
  </form>
</dialog>

<script src="/js/configuracoes.js?v=<%= assetVersion %>"></script>
<%- include('partials/footer') %>

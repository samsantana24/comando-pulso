<%- include('partials/head', { title: 'Confirmar 2º fator', bodyClass: 'auth', assetVersion: locals.assetVersion }) %>
  <main class="auth-screen">
    <div class="auth-bg" aria-hidden="true"></div>
    <div class="auth-card">
      <div class="auth-bracket auth-bracket-tl"></div>
      <div class="auth-bracket auth-bracket-tr"></div>
      <div class="auth-bracket auth-bracket-bl"></div>
      <div class="auth-bracket auth-bracket-br"></div>

      <div class="auth-brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32">
            <path d="M2 12 L7 12 L9 6 L12 18 L15 9 L17 12 L22 12"
                  stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                  stroke-linejoin="round" fill="none" />
          </svg>
        </span>
        <h1 class="auth-brand-name">PULSO</h1>
        <span class="auth-brand-sub">2º FATOR</span>
      </div>

      <p class="auth-eyebrow">verificação</p>
      <h2 class="auth-title">Código de acesso</h2>
      <p class="auth-greeting">Digite o código de 6 dígitos pra <strong><%= user.email %></strong>.</p>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form method="POST" action="/totp/verify" class="totp-form">
        <label class="form-label" for="token">Código do app</label>
        <input
          type="text" id="token" name="token"
          inputmode="numeric" pattern="[0-9 ]{6,7}" maxlength="7"
          autocomplete="one-time-code" autofocus required
        />
        <button type="submit" class="btn btn-primary btn-block">Entrar</button>
      </form>

      <form method="POST" action="/logout" class="logout-form-inline">
        <button type="submit" class="btn btn-ghost btn-small">Sair</button>
      </form>
    </div>
  </main>
<%- include('partials/footer') %>

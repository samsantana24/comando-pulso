<%- include('partials/head', { title: 'Entrar', bodyClass: 'auth', assetVersion: locals.assetVersion }) %>
  <main class="auth-screen">
    <div class="auth-bg" aria-hidden="true"></div>
    <div class="auth-card">
      <div class="auth-bracket auth-bracket-tl"></div>
      <div class="auth-bracket auth-bracket-tr"></div>
      <div class="auth-bracket auth-bracket-bl"></div>
      <div class="auth-bracket auth-bracket-br"></div>

      <div class="auth-brand">
        <span class="brand-mark" aria-hidden="true">
          <svg viewBox="0 0 24 24" width="32" height="32">
            <path d="M2 12 L7 12 L9 6 L12 18 L15 9 L17 12 L22 12"
                  stroke="currentColor" stroke-width="2.2" stroke-linecap="round"
                  stroke-linejoin="round" fill="none" />
          </svg>
        </span>
        <h1 class="auth-brand-name">PULSO</h1>
        <span class="auth-brand-sub">COMANDO</span>
      </div>

      <p class="auth-eyebrow">acesso restrito</p>
      <h2 class="auth-title">Centro de comando<br/>do <span class="text-accent">caixa</span></h2>

      <% if (error) { %>
        <div class="alert alert-error"><%= error %></div>
      <% } %>

      <form action="/auth/google" method="GET" class="auth-form">
        <button type="submit" class="btn btn-primary btn-block btn-google">
          <svg width="18" height="18" viewBox="0 0 18 18" aria-hidden="true">
            <path d="M17.64 9.2c0-.64-.06-1.25-.16-1.84H9v3.48h4.84c-.21 1.13-.84 2.09-1.79 2.73v2.27h2.9c1.7-1.56 2.69-3.87 2.69-6.64z" fill="#fff"/>
            <path d="M9 18c2.43 0 4.47-.81 5.96-2.18l-2.9-2.27c-.81.54-1.83.86-3.06.86-2.36 0-4.36-1.59-5.07-3.74H.96v2.34A8.997 8.997 0 0 0 9 18z" fill="#fff" opacity="0.85"/>
            <path d="M3.93 10.67A5.41 5.41 0 0 1 3.64 9c0-.58.1-1.14.29-1.67V4.99H.96A8.997 8.997 0 0 0 0 9c0 1.45.35 2.83.96 4.01l2.97-2.34z" fill="#fff" opacity="0.7"/>
            <path d="M9 3.58c1.32 0 2.51.45 3.44 1.35l2.58-2.58C13.46.89 11.43 0 9 0A8.997 8.997 0 0 0 .96 4.99l2.97 2.34C4.64 5.17 6.64 3.58 9 3.58z" fill="#fff" opacity="0.55"/>
          </svg>
          <span>Entrar com Google</span>
        </button>
      </form>

      <p class="auth-foot">
        Acesso autorizado apenas para contas <code>@usepulso.org</code>
      </p>
    </div>
  </main>
<%- include('partials/footer') %>

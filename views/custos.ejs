<%- include('partials/head', { title: title, assetVersion: locals.assetVersion }) %>
<%- include('partials/header', { title: title, user: user, userCan: userCan, scenarios: locals.scenarios, activeScenario: locals.activeScenario, assetVersion: locals.assetVersion }) %>
<script>
  window.PERMS = {
    edit_ads: <%= userCan('action.edit_ads') ? 'true' : 'false' %>,
    delete_ads: <%= userCan('action.delete_ads') ? 'true' : 'false' %>,
    edit_cost: <%= userCan('action.edit_cost') ? 'true' : 'false' %>,
    delete_cost: <%= userCan('action.delete_cost') ? 'true' : 'false' %>,
  };
</script>

<main class="container custos">
  <section class="toolbar">
    <form method="GET" action="/custos" class="weeks-selector" style="display: flex; gap: 12px; align-items: center; flex-wrap: wrap;">
      <label>Janela:
        <select name="weeks" onchange="if(this.value){document.getElementById('cf-from').value='';document.getElementById('cf-to').value='';}this.form.submit()">
          <% for (const opt of [1,2,3,4,5,6,8,10]) { %>
            <option value="<%= opt %>" <%= totalWeeks === opt && !locals.customFrom ? 'selected' : '' %>><%= opt %> sem.</option>
          <% } %>
        </select>
      </label>
      <label class="muted small">ou de:
        <input type="date" id="cf-from" name="from" value="<%= locals.customFrom || '' %>" />
      </label>
      <label class="muted small">até:
        <input type="date" id="cf-to" name="to" value="<%= locals.customTo || '' %>" />
      </label>
      <button type="submit" class="btn btn-ghost btn-small">Aplicar período</button>
    </form>
    <div class="cenario-info">
      Cenário: <strong><%= activeScenario ? activeScenario.name : '—' %></strong>
    </div>
    <button type="button" class="btn btn-ghost btn-with-icon" data-modal="todos-futuros" title="Ver e editar todos os custos previstos no futuro">
      <%- include('partials/icons', { name: 'refresh' }) %><span>Todos os futuros</span>
    </button>
    <% if (userCan('action.export_data')) { %>
      <button type="button" class="btn btn-ghost btn-with-icon" data-modal="export" title="Exportar dados em XLSX ou CSV">
        <%- include('partials/icons', { name: 'download' }) %><span>Exportar</span>
      </button>
    <% } %>
    <% const showToolbarActions = userCan('action.add_sale') || userCan('action.add_cost') || userCan('action.add_recurring_cost') || userCan('action.add_ads'); %>
    <% if (showToolbarActions) { %>
      <div class="toolbar-actions">
        <% if (userCan('action.add_sale')) { %>
          <button type="button" class="btn btn-primary btn-with-icon" data-modal="venda"><%- include('partials/icons', { name: 'tag' }) %><span>Venda</span></button>
        <% } %>
        <% if (userCan('action.add_cost')) { %>
          <button type="button" class="btn btn-primary btn-with-icon" data-modal="custo"><%- include('partials/icons', { name: 'minus' }) %><span>Custo</span></button>
        <% } %>
        <% if (userCan('action.add_cost')) { %>
          <button type="button" class="btn btn-ghost btn-with-icon" data-modal="custo-parcelado"><%- include('partials/icons', { name: 'refresh' }) %><span>Custo parcelado</span></button>
        <% } %>
        <% if (userCan('action.add_recurring_cost')) { %>
          <button type="button" class="btn btn-ghost btn-with-icon" data-modal="recorrente"><%- include('partials/icons', { name: 'refresh' }) %><span>Custo recorrente</span></button>
        <% } %>
        <% if (userCan('action.add_ads')) { %>
          <button type="button" class="btn btn-warn btn-with-icon" data-modal="ads"><%- include('partials/icons', { name: 'zap' }) %><span>Ads</span></button>
        <% } %>
      </div>
    <% } %>
  </section>

  <%- include('partials/data-entry', { closers: closers, activeScenario: activeScenario, today: today, categoriesByGroup: categoriesByGroup, scenarios: locals.scenarios }) %>

  <section class="weekly-grid-wrap">
    <table class="weekly-grid weekly-grid-split">
      <thead>
        <tr class="week-row">
          <th rowspan="2" class="cat-col">Categoria</th>
          <% for (const w of weeks) { %>
            <th colspan="2" class="week-h <%= w.is_current ? 'current' : (w.is_past ? 'past' : 'future') %>">
              <div class="week-label"><%= w.label %></div>
              <div class="week-id"><%= w.week_id %></div>
            </th>
          <% } %>
        </tr>
        <tr class="status-row">
          <% for (const w of weeks) { %>
            <th class="status-h paid-h">PAGO</th>
            <th class="status-h planned-h">A PAGAR</th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <tr class="row-vendas">
          <td>Vendas (líquido)</td>
          <% for (const w of weeks) { %>
            <% const v = salesByWeek[w.week_id] || 0 %>
            <td class="num cell-paid <%= v > 0 ? 'has-value pos' : '' %>"><%= v ? formatBrl(v) : '—' %></td>
            <td class="num cell-planned">—</td>
          <% } %>
        </tr>

        <tr class="row-section ads-section">
          <td colspan="<%= weeks.length * 2 + 1 %>">— INVESTIMENTO EM ADS —</td>
        </tr>
        <tr class="row-ads">
          <td>Tráfego Pago (Google / Meta Ads)</td>
          <% for (const w of weeks) { %>
            <% const paidV = adsPaidByWeek[w.week_id] || 0 %>
            <% const plannedV = adsPlannedByWeek[w.week_id] || 0 %>
            <% const totalV = (adsByWeek[w.week_id] || 0) %>
            <td class="num cell-paid <%= paidV > 0 ? 'has-value' : '' %>">
              <% if (paidV > 0) { %>
                <span class="cell-value"><%= formatBrl(paidV) %></span>
                <% if (userCan('action.edit_ads') || userCan('action.delete_ads')) { %>
                  <span class="cell-actions">
                    <% if (userCan('action.edit_ads')) { %>
                      <button type="button" class="cell-action-btn" title="Editar ads desta semana" data-action="edit-ads-week" data-week-start="<%= w.sun %>" data-week-id="<%= w.week_id %>" data-amount="<%= totalV %>">✎</button>
                    <% } %>
                    <% if (userCan('action.delete_ads')) { %>
                      <button type="button" class="cell-action-btn delete" title="Remover ads desta semana" data-action="delete-ads-week" data-week-start="<%= w.sun %>" data-week-id="<%= w.week_id %>" data-amount="<%= totalV %>">×</button>
                    <% } %>
                  </span>
                <% } %>
              <% } else { %>—<% } %>
            </td>
            <td class="num cell-planned <%= plannedV > 0 ? 'has-value' : '' %>">
              <% if (plannedV > 0) { %>
                <span class="cell-value"><%= formatBrl(plannedV) %></span>
                <% if (userCan('action.edit_ads')) { %>
                  <span class="cell-actions">
                    <button type="button" class="cell-action-btn" title="Editar ads desta semana" data-action="edit-ads-week" data-week-start="<%= w.sun %>" data-week-id="<%= w.week_id %>" data-amount="<%= totalV %>">✎</button>
                  </span>
                <% } %>
              <% } else { %>—<% } %>
            </td>
          <% } %>
        </tr>
        <tr class="row-subtotal ads-subtotal">
          <td>Total Ads na semana</td>
          <% for (const w of weeks) { %>
            <% const paidV = adsPaidByWeek[w.week_id] || 0 %>
            <% const plannedV = adsPlannedByWeek[w.week_id] || 0 %>
            <td class="num cell-paid <%= paidV > 0 ? 'has-value' : '' %>"><%= paidV > 0 ? formatBrl(paidV) : '—' %></td>
            <td class="num cell-planned <%= plannedV > 0 ? 'has-value' : '' %>"><%= plannedV > 0 ? formatBrl(plannedV) : '—' %></td>
          <% } %>
        </tr>

        <% for (const grp of orderedGroupsPresent) { %>
          <tr class="row-section">
            <td colspan="<%= weeks.length * 2 + 1 %>"><%= grp %></td>
          </tr>
          <% for (const cat of Object.keys(costsByGroup[grp]).sort()) { %>
            <tr class="cat-row" data-category="<%- cat.replace(/"/g, '&quot;') %>" data-from="<%= weeks[0].sun %>" data-to="<%= weeks[weeks.length-1].sat %>">
              <td class="cat-cell"><button type="button" class="cat-toggle" aria-expanded="false" title="Expandir / ver itens"><span class="cat-chev">▸</span> <%= cat %></button></td>
              <% for (const w of weeks) { %>
                <% const paidV = (costsByGroupPaid[grp] && costsByGroupPaid[grp][cat] && costsByGroupPaid[grp][cat][w.week_id]) || 0 %>
                <% const plannedV = (costsByGroupPlanned[grp] && costsByGroupPlanned[grp][cat] && costsByGroupPlanned[grp][cat][w.week_id]) || 0 %>
                <td class="num cell-paid <%= paidV > 0 ? 'has-value' : '' %>">
                  <% if (paidV > 0) { %>
                    <span class="cell-value"><%= formatBrl(paidV) %></span>
                    <% if (userCan('action.edit_cost')) { %>
                      <span class="cell-actions">
                        <button type="button" class="cell-action-btn revert" data-action="revert-paid" data-week="<%= w.week_id %>" data-week-start="<%= w.sun %>" data-week-end="<%= w.sat %>" data-category="<%= cat %>" data-group="<%= grp %>" title="Reverter para 'a pagar'">↩</button>
                      </span>
                    <% } %>
                  <% } else { %>—<% } %>
                </td>
                <td class="num cell-planned <%= plannedV > 0 ? 'has-value' : '' %>">
                  <% if (plannedV > 0) { %>
                    <span class="cell-value"><%= formatBrl(plannedV) %></span>
                    <% if (userCan('action.edit_cost')) { %>
                      <span class="cell-actions">
                        <button type="button" class="cell-action-btn pay" data-action="mark-paid" data-week="<%= w.week_id %>" data-week-start="<%= w.sun %>" data-week-end="<%= w.sat %>" data-category="<%= cat %>" data-group="<%= grp %>" title="Marcar como pago">✓</button>
                      </span>
                    <% } %>
                  <% } else { %>—<% } %>
                </td>
              <% } %>
            </tr>
            <tr class="cat-detail-row" hidden>
              <td colspan="<%= weeks.length * 2 + 1 %>" class="cat-detail-cell">
                <div class="cat-detail-content"><span class="muted small">Clique pra carregar os custos individuais...</span></div>
              </td>
            </tr>
          <% } %>
          <tr class="row-subtotal">
            <td>Subtotal <%= grp %></td>
            <% for (const w of weeks) { %>
              <% const paidV = (subtotalByGroupPaid[grp] && subtotalByGroupPaid[grp][w.week_id]) || 0 %>
              <% const plannedV = (subtotalByGroupPlanned[grp] && subtotalByGroupPlanned[grp][w.week_id]) || 0 %>
              <td class="num cell-paid <%= paidV > 0 ? 'has-value' : '' %>"><%= paidV > 0 ? formatBrl(paidV) : '—' %></td>
              <td class="num cell-planned <%= plannedV > 0 ? 'has-value' : '' %>"><%= plannedV > 0 ? formatBrl(plannedV) : '—' %></td>
            <% } %>
          </tr>
        <% } %>

        <tr class="row-saldo">
          <td>Saldo da semana</td>
          <% for (const w of weeks) { %>
            <% const split = balanceByWeekSplit[w.week_id] || { paid: 0, planned: 0 } %>
            <td class="num cell-paid has-value <%= split.paid > 0 ? 'pos' : (split.paid < 0 ? 'neg' : '') %>"><%= formatBrl(split.paid) %></td>
            <td class="num cell-planned has-value <%= split.planned < 0 ? 'neg' : '' %>"><%= formatBrl(split.planned) %></td>
          <% } %>
        </tr>
      </tbody>
    </table>
    <% if (orderedGroupsPresent.length === 0 && Object.values(salesByWeek).every((v) => v === 0) && Object.values(adsByWeek).every((v) => v === 0)) { %>
      <p class="empty-hint muted">Sem lançamentos nesta janela. Comece adicionando uma venda, um custo ou um investimento em ads.</p>
    <% } %>
  </section>

  <section class="ads-history">
    <h3>Investimento em Ads — histórico</h3>
    <p class="muted">Cada semana mostra o total investido. Clique em "editar" para alterar valor ou em "remover" para apagar os 7 lançamentos diários.</p>
    <div class="ads-history-table-wrap">
      <table class="ads-history-table">
        <thead>
          <tr>
            <th>Semana</th>
            <th>Período</th>
            <th class="num">Total</th>
            <th class="num">Diário</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="ads-history-tbody">
          <tr><td colspan="5" class="muted center">Carregando…</td></tr>
        </tbody>
      </table>
    </div>
  </section>

  <section class="entries-grid">
    <div class="entries-col">
      <h3>Vendas recentes</h3>
      <% if (recentSales.length === 0) { %>
        <p class="muted">Nenhuma venda ainda.</p>
      <% } %>
      <ul class="entries-list">
        <% for (const s of recentSales) { %>
          <li>
            <div class="entry-line">
              <strong><%= formatBrl(s.net_amount) %></strong>
              <span class="muted">líq. · <%= formatDateShort(s.date) %></span>
            </div>
            <div class="entry-line muted">
              bruto <%= formatBrl(s.gross_amount) %>
              <% if (s.client_name) { %> · <%= s.client_name %><% } %>
              <% if (s.payment_method) { %> · <%= formatPaymentMethod(s.payment_method) %><% } %>
            </div>
            <div class="entry-actions">
              <% if (userCan('action.edit_sale')) { %>
                <button type="button" data-action="edit-sale" data-payload='<%- JSON.stringify(s) %>' class="btn-link">editar</button>
              <% } %>
              <% if (userCan('action.delete_sale')) { %>
                <button type="button" data-action="delete" data-url="/api/sales/<%= s.id %>" class="btn-link danger">excluir</button>
              <% } %>
            </div>
          </li>
        <% } %>
      </ul>
    </div>
    <div class="entries-col">
      <h3>Custos recentes (janela)</h3>
      <% if (recentCosts.length === 0) { %>
        <p class="muted">Nenhum custo na janela atual.</p>
      <% } %>
      <ul class="entries-list">
        <% for (const c of recentCosts) { %>
          <% const parcel = parseParcel(c.description); %>
          <li class="<%= parcel ? 'is-parcel' : '' %>">
            <div class="entry-line">
              <% if (parcel) { %><span class="parcel-icon" title="Parcela <%= parcel.current %> de <%= parcel.total %>">⛓</span><% } %>
              <strong><%= formatBrl(c.amount) %></strong>
              <span class="muted"><%= formatDateShort(c.date) %></span>
              <span class="badge <%= c.status %>"><%= c.status === 'paid' ? 'pago' : 'previsto' %></span>
              <% if (parcel) { %><span class="parcel-tag"><%= parcel.current %>/<%= parcel.total %></span><% } %>
              <% if (c.recurrence_id) { %><span class="badge recur">recorrente</span><% } %>
            </div>
            <div class="entry-line muted">
              <%= c.category %><% if (c.description) { %> · <%= c.description %><% } %>
            </div>
            <div class="entry-actions">
              <% if (userCan('action.edit_cost')) { %>
                <button type="button" data-action="edit-cost" data-payload='<%- JSON.stringify(c) %>' class="btn-link">editar</button>
              <% } %>
              <% if (userCan('action.delete_cost')) { %>
                <button type="button" data-action="delete" data-url="/api/costs/<%= c.id %>" class="btn-link danger">excluir</button>
              <% } %>
            </div>
          </li>
        <% } %>
      </ul>
    </div>
  </section>

  <section class="receivables-panel" id="receivables">
    <div class="receivables-header">
      <div>
        <h2>Recebíveis</h2>
        <span class="subtitle">Todos os pendentes (sem limite) · clique numa linha pra ver detalhes</span>
      </div>
      <% if (userCan('action.export_data')) { %>
        <button type="button" class="btn btn-ghost btn-small btn-with-icon" data-modal="export" data-export-default="receivables">
          <%- include('partials/icons', { name: 'download' }) %><span>Exportar</span>
        </button>
      <% } %>
    </div>

    <div class="receivables-summary">
      <div class="recv-mini-card <%= recvSummary.thisWeek.count > 0 ? 'is-current' : '' %>">
        <div class="label">Esta semana</div>
        <div class="value"><%= formatBrl(recvSummary.thisWeek.sum) %></div>
        <div class="meta"><%= recvSummary.thisWeek.count %> conta(s)</div>
      </div>
      <div class="recv-mini-card">
        <div class="label">Próxima semana</div>
        <div class="value"><%= formatBrl(recvSummary.nextWeek.sum) %></div>
        <div class="meta"><%= recvSummary.nextWeek.count %> conta(s)</div>
      </div>
      <div class="recv-mini-card">
        <div class="label">Em 30 dias</div>
        <div class="value"><%= formatBrl(recvSummary.in30.sum) %></div>
        <div class="meta"><%= recvSummary.in30.count %> conta(s)</div>
      </div>
      <div class="recv-mini-card">
        <div class="label">Total janela</div>
        <div class="value"><%= formatBrl(recvSummary.inWindow.sum) %></div>
        <div class="meta"><%= recvSummary.inWindow.count %> conta(s)</div>
      </div>
    </div>

    <div class="receivables-filters">
      <button type="button" class="filter-chip is-active" data-filter="all">Todos</button>
      <button type="button" class="filter-chip" data-filter="overdue">Vencidos</button>
      <button type="button" class="filter-chip" data-filter="this-week">Esta semana</button>
      <button type="button" class="filter-chip" data-filter="next-7">Próximos 7d</button>
      <button type="button" class="filter-chip" data-filter="next-30">Próximos 30d</button>
      <button type="button" class="filter-chip" data-filter="next-60">Próximos 60d</button>
    </div>

    <table class="receivables-table">
      <thead>
        <tr>
          <th>Vencimento</th>
          <th>Cliente</th>
          <th class="num">Valor</th>
          <th>Pagamento</th>
          <th class="actions-h">Ações</th>
        </tr>
      </thead>
      <tbody>
        <% for (const r of pendingReceivables) { %>
          <% const isOverdue = r.expected_date < todayDate; %>
          <tr data-receivable-id="<%= r.id %>" data-expected-date="<%= r.expected_date %>" class="<%= isOverdue ? 'overdue' : '' %>">
            <td>
              <%= formatDateShort(r.expected_date) %>
              <% if (isOverdue) { %><span class="badge overdue-badge">VENCIDO</span><% } %>
            </td>
            <td><%= r.client_name || '—' %></td>
            <td class="num"><%= formatBrl(r.expected_amount) %></td>
            <td><%= r.payment_method ? formatPaymentMethod(r.payment_method) : '—' %></td>
            <td class="actions-cell">
              <% if (userCan('action.mark_received')) { %>
                <button type="button" class="cell-action-btn pay" data-action="receive-receivable" data-id="<%= r.id %>" data-payload='<%- JSON.stringify(r) %>' title="Marcar recebido">✓</button>
              <% } %>
              <% if (userCan('action.delete_receivable')) { %>
                <button type="button" class="cell-action-btn delete" data-action="delete-receivable" data-id="<%= r.id %>" title="Cancelar/excluir">×</button>
              <% } %>
            </td>
          </tr>
        <% } %>
        <% if (pendingReceivables.length === 0) { %>
          <tr><td colspan="5" class="muted center" style="padding: 32px;">Nenhuma conta a receber pendente.</td></tr>
        <% } %>
      </tbody>
    </table>
  </section>

  <!-- Catálogo de categorias (Rachel + Sâmeque) -->
  <% if (userCan('action.add_category') || userCan('action.edit_category') || userCan('action.delete_category')) { %>
  <section class="settings-card" style="margin-top: 24px;">
    <h2>Categorias de custo</h2>
    <p class="muted">Organize as categorias por grupo. Renomear uma categoria atualiza automaticamente todos os custos que a usam.</p>
    <% if (userCan('action.add_category')) { %>
      <button type="button" class="btn btn-primary btn-small" id="btn-new-category">+ Nova categoria</button>
    <% } %>
    <div class="cat-groups" id="cat-groups">
      <% for (const grp of orderedCatGroups) { %>
        <div class="cat-group">
          <h3><%= grp %></h3>
          <ul class="cat-list">
            <% for (const c of (categoriesByGroupFull[grp] || [])) { %>
              <li data-id="<%= c.id %>">
                <span class="cat-name"><%= c.name %></span>
                <span class="cat-actions">
                  <% if (userCan('action.edit_category')) { %>
                    <button type="button" class="btn-link" data-action="edit-category" data-id="<%= c.id %>" data-name="<%- c.name.replace(/"/g, '&quot;') %>" data-group="<%- c.group_name.replace(/"/g, '&quot;') %>">editar</button>
                  <% } %>
                  <% if (userCan('action.delete_category')) { %>
                    <button type="button" class="btn-link danger" data-action="delete-category" data-id="<%= c.id %>" data-name="<%- c.name.replace(/"/g, '&quot;') %>">excluir</button>
                  <% } %>
                </span>
              </li>
            <% } %>
          </ul>
        </div>
      <% } %>
    </div>
  </section>
  <% } %>

  <!-- Todos os custos (busca/edição) -->
  <% if (userCan('action.edit_cost') || userCan('action.delete_cost') || userCan('nav.custos')) { %>
  <section class="receivables-section" style="margin-top: 24px;">
    <div class="recv-head">
      <div>
        <span class="t-eyebrow">TODOS OS CUSTOS</span>
        <span class="subtitle">Busca completa — clique numa linha pra editar</span>
      </div>
    </div>
    <div class="all-costs-filters" style="display: flex; flex-wrap: wrap; gap: 12px; align-items: end; padding: 12px 0;">
      <label class="form-label" style="margin: 0;">De
        <input type="date" id="all-costs-from" value="<%= weeks[0].sun.slice(0, 7) + '-01' %>" />
      </label>
      <label class="form-label" style="margin: 0;">Até
        <input type="date" id="all-costs-to" value="2030-12-31" />
      </label>
      <label class="form-label" style="margin: 0;">Categoria
        <select id="all-costs-cat">
          <option value="">Todas</option>
          <% for (const grp of orderedCatGroups) { %>
            <optgroup label="<%= grp %>">
              <% for (const c of (categoriesByGroupFull[grp] || [])) { %>
                <option value="<%= c.name %>"><%= c.name %></option>
              <% } %>
            </optgroup>
          <% } %>
        </select>
      </label>
      <label class="form-label" style="margin: 0;">Status
        <select id="all-costs-status">
          <option value="">Todos</option>
          <option value="paid">Pago</option>
          <option value="planned">A pagar</option>
        </select>
      </label>
      <button type="button" class="btn btn-primary btn-small" id="btn-all-costs-search">Buscar</button>
      <span class="muted" id="all-costs-count"></span>
    </div>
    <div style="overflow-x: auto;">
      <table class="rec-table" id="all-costs-table">
        <thead>
          <tr>
            <th>Data</th>
            <th>Categoria</th>
            <th>Descrição</th>
            <th class="num">Valor</th>
            <th>Status</th>
            <th>Ações</th>
          </tr>
        </thead>
        <tbody id="all-costs-tbody">
          <tr><td colspan="6" class="muted center" style="padding: 20px;">Clique em "Buscar" pra carregar.</td></tr>
        </tbody>
      </table>
    </div>
  </section>
  <% } %>
</main>

<dialog id="modal-category" class="modal">
  <form id="form-category">
    <h2 id="modal-cat-title">Nova categoria</h2>
    <input type="hidden" name="id" />
    <label class="form-label">Nome
      <input type="text" name="name" required />
    </label>
    <label class="form-label">Grupo
      <select name="group_name" required>
        <% for (const grp of orderedCatGroups) { %>
          <option value="<%= grp %>"><%= grp %></option>
        <% } %>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar</button>
    </div>
  </form>
</dialog>

<dialog id="modal-edit-sale" class="modal">
  <form class="api-form" data-endpoint="" data-method="PATCH">
    <h2>Editar venda</h2>
    <label class="form-label">Data
      <input type="date" name="date" required />
    </label>
    <div class="form-row">
      <label class="form-label">Valor bruto (R$)
        <input type="number" name="gross_amount" step="0.01" min="0" required />
      </label>
      <label class="form-label">Valor líquido (R$)
        <input type="number" name="net_amount" step="0.01" min="0" required />
      </label>
    </div>
    <label class="form-label">Cliente
      <input type="text" name="client_name" />
    </label>
    <div class="form-row">
      <label class="form-label">Closer
        <select name="closer_id">
          <option value="">—</option>
          <% for (const c of closers) { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% } %>
        </select>
      </label>
      <label class="form-label">Pagamento
        <select name="payment_method">
          <option value="">—</option>
          <option value="pix">Pix</option>
          <option value="cartao_avista">Cartão à vista</option>
          <option value="cartao_2x">Cartão 2x</option>
          <option value="cartao_6x">Cartão 6x</option>
          <option value="cartao_12x">Cartão 12x</option>
          <option value="outro">Outro</option>
        </select>
      </label>
    </div>
    <label class="form-label">Observações
      <textarea name="notes" rows="2"></textarea>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar alterações</button>
    </div>
  </form>
</dialog>

<dialog id="modal-edit-cost" class="modal">
  <form class="api-form" data-endpoint="" data-method="PATCH">
    <h2>Editar custo</h2>
    <div class="form-row">
      <label class="form-label">Data
        <input type="date" name="date" required />
      </label>
      <label class="form-label">Valor (R$)
        <input type="number" name="amount" step="0.01" min="0" required />
      </label>
    </div>
    <label class="form-label">Categoria
      <input list="categorias-list" name="category" required />
    </label>
    <label class="form-label">Descrição
      <input type="text" name="description" />
    </label>
    <label class="form-label">Status
      <select name="status">
        <option value="planned">Previsto</option>
        <option value="paid">Pago</option>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar alterações</button>
    </div>
  </form>
</dialog>

<dialog id="modal-receive" class="modal">
  <form id="form-receive">
    <h2>Marcar recebível como recebido</h2>
    <input type="hidden" name="id" />
    <label class="form-label">Data do recebimento
      <input type="date" name="received_date" required />
    </label>
    <label class="form-label">Valor líquido recebido (R$) <span class="muted">(pode editar)</span>
      <input type="number" name="net_amount" step="0.01" min="0" required />
    </label>
    <p class="muted" id="receive-preview"></p>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Confirmar recebimento</button>
    </div>
  </form>
</dialog>

<script src="/js/data-entry.js?v=<%= assetVersion %>"></script>
<script src="/js/custos.js?v=<%= assetVersion %>"></script>
<%- include('partials/footer') %>

<%- include('partials/head', { title: title, assetVersion: locals.assetVersion }) %>
<%- include('partials/header', { title: title, user: user, userCan: userCan, scenarios: locals.scenarios, activeScenario: locals.activeScenario, assetVersion: locals.assetVersion }) %>

<main class="container custos">
  <section class="toolbar">
    <form method="GET" action="/custos" class="weeks-selector">
      <label>Janela:
        <select name="weeks" onchange="this.form.submit()">
          <% for (const opt of [1,2,3,4,5,6,8,10]) { %>
            <option value="<%= opt %>" <%= totalWeeks === opt ? 'selected' : '' %>><%= opt %> sem.</option>
          <% } %>
        </select>
      </label>
    </form>
    <div class="cenario-info">
      Cenário: <strong><%= activeScenario ? activeScenario.name : '—' %></strong>
    </div>
    <% const showToolbarActions = userCan('action.add_sale') || userCan('action.add_cost') || userCan('action.add_recurring_cost') || userCan('action.add_ads'); %>
    <% if (showToolbarActions) { %>
      <div class="toolbar-actions">
        <% if (userCan('action.add_sale')) { %>
          <button type="button" class="btn btn-primary" data-modal="venda">+ Venda</button>
        <% } %>
        <% if (userCan('action.add_cost')) { %>
          <button type="button" class="btn btn-primary" data-modal="custo">+ Custo</button>
        <% } %>
        <% if (userCan('action.add_recurring_cost')) { %>
          <button type="button" class="btn btn-ghost" data-modal="recorrente">+ Custo recorrente</button>
        <% } %>
        <% if (userCan('action.add_ads')) { %>
          <button type="button" class="btn btn-warn" data-modal="ads">+ Investimento em Ads</button>
        <% } %>
      </div>
    <% } %>
  </section>

  <%- include('partials/data-entry', { closers: closers, activeScenario: activeScenario, today: today, categoriesByGroup: categoriesByGroup }) %>

  <section class="weekly-grid-wrap">
    <table class="weekly-grid">
      <thead>
        <tr>
          <th>Categoria</th>
          <% for (const w of weeks) { %>
            <th class="week-h <%= w.is_current ? 'current' : (w.is_past ? 'past' : 'future') %>">
              <div class="week-label"><%= w.label %></div>
              <div class="week-id"><%= w.week_id %></div>
            </th>
          <% } %>
        </tr>
      </thead>
      <tbody>
        <tr class="row-vendas">
          <td>Vendas (líquido)</td>
          <% for (const w of weeks) { %>
            <% const v = salesByWeek[w.week_id] || 0 %>
            <td class="amount <%= v > 0 ? 'pos' : '' %>"><%= v ? formatBrl(v) : '—' %></td>
          <% } %>
        </tr>

        <tr class="row-section ads-section">
          <td colspan="<%= weeks.length + 1 %>">— INVESTIMENTO EM ADS —</td>
        </tr>
        <tr class="row-ads">
          <td>Tráfego Pago (Google / Meta Ads)</td>
          <% for (const w of weeks) { %>
            <% const v = adsByWeek[w.week_id] || 0 %>
            <td class="amount ads <%= v > 0 ? 'has' : '' %>"><%= v ? formatBrl(v) : '—' %></td>
          <% } %>
        </tr>
        <tr class="row-subtotal ads-subtotal">
          <td>Total Ads na semana</td>
          <% for (const w of weeks) { %>
            <% const v = adsByWeek[w.week_id] || 0 %>
            <td class="amount ads"><%= formatBrl(v) %></td>
          <% } %>
        </tr>

        <% for (const grp of orderedGroupsPresent) { %>
          <tr class="row-section">
            <td colspan="<%= weeks.length + 1 %>"><%= grp %></td>
          </tr>
          <% for (const cat of Object.keys(costsByGroup[grp]).sort()) { %>
            <tr>
              <td><%= cat %></td>
              <% for (const w of weeks) { %>
                <% const v = (costsByGroup[grp][cat] && costsByGroup[grp][cat][w.week_id]) || 0 %>
                <td class="amount <%= v > 0 ? 'cost' : '' %>"><%= v ? formatBrl(v) : '—' %></td>
              <% } %>
            </tr>
          <% } %>
          <tr class="row-subtotal">
            <td>Subtotal <%= grp %></td>
            <% for (const w of weeks) { %>
              <% const v = (subtotalByGroupWeek[grp] && subtotalByGroupWeek[grp][w.week_id]) || 0 %>
              <td class="amount cost"><%= formatBrl(v) %></td>
            <% } %>
          </tr>
        <% } %>

        <tr class="row-saldo">
          <td>Saldo da semana</td>
          <% for (const w of weeks) { %>
            <% const b = balanceByWeek[w.week_id] || 0 %>
            <td class="amount <%= b > 0 ? 'pos' : (b < 0 ? 'neg' : '') %>"><%= formatBrl(b) %></td>
          <% } %>
        </tr>
      </tbody>
    </table>
    <% if (orderedGroupsPresent.length === 0 && Object.values(salesByWeek).every((v) => v === 0) && Object.values(adsByWeek).every((v) => v === 0)) { %>
      <p class="empty-hint muted">Sem lançamentos nesta janela. Comece adicionando uma venda, um custo ou um investimento em ads.</p>
    <% } %>
  </section>

  <section class="entries-grid">
    <div class="entries-col">
      <h3>Vendas recentes</h3>
      <% if (recentSales.length === 0) { %>
        <p class="muted">Nenhuma venda ainda.</p>
      <% } %>
      <ul class="entries-list">
        <% for (const s of recentSales) { %>
          <li>
            <div class="entry-line">
              <strong><%= formatBrl(s.net_amount) %></strong>
              <span class="muted">líq. · <%= formatDateShort(s.date) %></span>
            </div>
            <div class="entry-line muted">
              bruto <%= formatBrl(s.gross_amount) %>
              <% if (s.client_name) { %> · <%= s.client_name %><% } %>
              <% if (s.payment_method) { %> · <%= formatPaymentMethod(s.payment_method) %><% } %>
            </div>
            <div class="entry-actions">
              <% if (userCan('action.edit_sale')) { %>
                <button type="button" data-action="edit-sale" data-payload='<%- JSON.stringify(s) %>' class="btn-link">editar</button>
              <% } %>
              <% if (userCan('action.delete_sale')) { %>
                <button type="button" data-action="delete" data-url="/api/sales/<%= s.id %>" class="btn-link danger">excluir</button>
              <% } %>
            </div>
          </li>
        <% } %>
      </ul>
    </div>
    <div class="entries-col">
      <h3>Custos recentes (janela)</h3>
      <% if (recentCosts.length === 0) { %>
        <p class="muted">Nenhum custo na janela atual.</p>
      <% } %>
      <ul class="entries-list">
        <% for (const c of recentCosts) { %>
          <li>
            <div class="entry-line">
              <strong><%= formatBrl(c.amount) %></strong>
              <span class="muted"><%= formatDateShort(c.date) %></span>
              <span class="badge <%= c.status %>"><%= c.status === 'paid' ? 'pago' : 'previsto' %></span>
              <% if (c.recurrence_id) { %><span class="badge recur">recorrente</span><% } %>
            </div>
            <div class="entry-line muted">
              <%= c.category %><% if (c.description) { %> · <%= c.description %><% } %>
            </div>
            <div class="entry-actions">
              <% if (userCan('action.edit_cost')) { %>
                <button type="button" data-action="edit-cost" data-payload='<%- JSON.stringify(c) %>' class="btn-link">editar</button>
              <% } %>
              <% if (userCan('action.delete_cost')) { %>
                <button type="button" data-action="delete" data-url="/api/costs/<%= c.id %>" class="btn-link danger">excluir</button>
              <% } %>
            </div>
          </li>
        <% } %>
      </ul>
    </div>
  </section>

  <section class="receivables-section">
    <h3>Recebíveis pendentes <span class="muted">(próximos 60 dias)</span></h3>
    <% if (pendingReceivables.length === 0) { %>
      <p class="muted">Nenhum recebível pendente.</p>
    <% } else { %>
      <table class="rec-table">
        <thead>
          <tr>
            <th>Data prevista</th>
            <th class="num">Valor</th>
            <th>Cliente</th>
            <th>Método</th>
            <th></th>
          </tr>
        </thead>
        <tbody>
          <% for (const r of pendingReceivables) { %>
            <% const overdue = r.expected_date < todayDate %>
            <tr class="<%= overdue ? 'overdue' : '' %>">
              <td><%= formatDateShort(r.expected_date) %><% if (overdue) { %> <span class="badge overdue-badge">vencido</span><% } %></td>
              <td class="num"><strong><%= formatBrl(r.expected_amount) %></strong></td>
              <td><%= r.client_name || '—' %></td>
              <td><%= formatPaymentMethod(r.payment_method) %></td>
              <td>
                <button type="button" class="btn-link" data-action="receive-receivable" data-id="<%= r.id %>" data-payload='<%- JSON.stringify(r) %>'>marcar recebido</button>
                <button type="button" class="btn-link danger" data-action="delete-receivable" data-id="<%= r.id %>">cancelar</button>
              </td>
            </tr>
          <% } %>
        </tbody>
      </table>
    <% } %>
  </section>
</main>

<dialog id="modal-edit-sale" class="modal">
  <form class="api-form" data-endpoint="" data-method="PATCH">
    <h2>Editar venda</h2>
    <label class="form-label">Data
      <input type="date" name="date" required />
    </label>
    <div class="form-row">
      <label class="form-label">Valor bruto (R$)
        <input type="number" name="gross_amount" step="0.01" min="0" required />
      </label>
      <label class="form-label">Valor líquido (R$)
        <input type="number" name="net_amount" step="0.01" min="0" required />
      </label>
    </div>
    <label class="form-label">Cliente
      <input type="text" name="client_name" />
    </label>
    <div class="form-row">
      <label class="form-label">Closer
        <select name="closer_id">
          <option value="">—</option>
          <% for (const c of closers) { %>
            <option value="<%= c.id %>"><%= c.name %></option>
          <% } %>
        </select>
      </label>
      <label class="form-label">Pagamento
        <select name="payment_method">
          <option value="">—</option>
          <option value="pix">Pix</option>
          <option value="cartao_avista">Cartão à vista</option>
          <option value="cartao_2x">Cartão 2x</option>
          <option value="cartao_6x">Cartão 6x</option>
          <option value="cartao_12x">Cartão 12x</option>
          <option value="outro">Outro</option>
        </select>
      </label>
    </div>
    <label class="form-label">Observações
      <textarea name="notes" rows="2"></textarea>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar alterações</button>
    </div>
  </form>
</dialog>

<dialog id="modal-edit-cost" class="modal">
  <form class="api-form" data-endpoint="" data-method="PATCH">
    <h2>Editar custo</h2>
    <div class="form-row">
      <label class="form-label">Data
        <input type="date" name="date" required />
      </label>
      <label class="form-label">Valor (R$)
        <input type="number" name="amount" step="0.01" min="0" required />
      </label>
    </div>
    <label class="form-label">Categoria
      <input list="categorias-list" name="category" required />
    </label>
    <label class="form-label">Descrição
      <input type="text" name="description" />
    </label>
    <label class="form-label">Status
      <select name="status">
        <option value="planned">Previsto</option>
        <option value="paid">Pago</option>
      </select>
    </label>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Salvar alterações</button>
    </div>
  </form>
</dialog>

<dialog id="modal-receive" class="modal">
  <form id="form-receive">
    <h2>Marcar recebível como recebido</h2>
    <input type="hidden" name="id" />
    <label class="form-label">Data do recebimento
      <input type="date" name="received_date" required />
    </label>
    <label class="form-label">Valor líquido recebido (R$) <span class="muted">(pode editar)</span>
      <input type="number" name="net_amount" step="0.01" min="0" required />
    </label>
    <p class="muted" id="receive-preview"></p>
    <div class="modal-actions">
      <button type="button" class="btn btn-ghost" data-close-modal>Cancelar</button>
      <button type="submit" class="btn btn-primary">Confirmar recebimento</button>
    </div>
  </form>
</dialog>

<script src="/js/data-entry.js?v=<%= assetVersion %>"></script>
<script src="/js/custos.js?v=<%= assetVersion %>"></script>
<%- include('partials/footer') %>
